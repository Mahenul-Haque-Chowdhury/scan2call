# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://scan2call:scan2call@localhost:5432/scan2call

# ──────────────────────────────────────────────
# Auth (JWT)
# ──────────────────────────────────────────────
JWT_ACCESS_PRIVATE_KEY=BASE64_ENCODED_RSA_PRIVATE_KEY
JWT_ACCESS_PUBLIC_KEY=BASE64_ENCODED_RSA_PUBLIC_KEY
JWT_REFRESH_SECRET=your-refresh-secret-here

# ──────────────────────────────────────────────
# Google OAuth
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ──────────────────────────────────────────────
# Facebook OAuth
# ──────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/facebook/callback

# ──────────────────────────────────────────────
# Twilio
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_VERIFY_SERVICE_SID=

# ──────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=

# ──────────────────────────────────────────────
# Stripe (Frontend)
# ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@scan2call.com.au

# ──────────────────────────────────────────────
# S3-Compatible Storage (Cloudflare R2)
# ──────────────────────────────────────────────
S3_BUCKET=scan2call-media
S3_REGION=ap-southeast-2
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_URL=

# ──────────────────────────────────────────────
# App URLs
# ──────────────────────────────────────────────
APP_URL=http://localhost:3002
API_URL=http://localhost:3001
API_PORT=3001
NODE_ENV=development

# ──────────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ──────────────────────────────────────────────
# Redis (rate limiting, caching)
# ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# ISR Revalidation (Next.js)
# ──────────────────────────────────────────────
REVALIDATION_SECRET=your-revalidation-secret-here
