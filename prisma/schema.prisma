// ──────────────────────────────────────────────
// Scan2Call — Prisma Schema
// ──────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  CUSTOMER
  FINDER
}

enum TagType {
  PET_COLLAR
  CAR_STICKER
  LUGGAGE_TAG
  KEYCHAIN
  MEDICAL_BAND
  GENERIC
}

enum TagStatus {
  INACTIVE
  ACTIVE
  LOST
  FOUND
  DEACTIVATED
}

enum QrFrameStyle {
  SCAN2CALL_TOP
  SCAN2CALL_BOTTOM
  NONE
}

enum QrLayout {
  STANDARD
  WINDSHIELD_CARD
  PASSPORT_STICKER_HORIZONTAL
  PASSPORT_STICKER_VERTICAL
}

enum CommunicationType {
  VOICE_CALL
  SMS
  WHATSAPP
  LOCATION_SHARE
}

enum CommunicationStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum GiftCodeStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REVOKED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentType {
  PURCHASE
  RENEWAL
}

enum AdminActionType {
  USER_SUSPENDED
  USER_UNSUSPENDED
  TAG_DEACTIVATED
  TAG_REACTIVATED
  TAG_ASSIGNED_TO_USER
  TAG_BATCH_GENERATED
  TAG_BATCH_DELETED
  TAG_CSV_IMPORTED
  ORDER_UPDATED
  PRODUCT_UPDATED
  REFUND_ISSUED
  MODERATION_ACTION
  QR_GENERATED
  ORDER_TAGS_ACTIVATED
}

enum ContactMessageStatus {
  NEW
  REPLIED
  ARCHIVED
}

// ──────────────────────────────────────────────
// USERS
// ──────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  googleId        String?   @unique
  facebookId      String?   @unique
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  phone           String?   @unique
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?
  whatsappPhone   String?
  passwordHash    String?
  firstName       String
  lastName        String
  role            Role      @default(CUSTOMER)
  avatarUrl       String?
  timezone        String    @default("Australia/Sydney")

  // Notification preferences
  notifyOnScan   Boolean @default(true)
  notifyViaSms   Boolean @default(true)
  notifyViaEmail Boolean @default(true)
  notifyViaPush  Boolean @default(false)

  // Stripe link
  stripeCustomerId             String? @unique
  // Saved off-session payment method for tag auto-renewal charges
  stripeDefaultPaymentMethodId String?

  // Account state
  isSuspended     Boolean   @default(false)
  suspendedAt     DateTime?
  suspendedReason String?
  lastLoginAt     DateTime?

  // Soft delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tags                   Tag[]
  savedAddresses         SavedAddress[]
  scans                  Scan[]
  orders                 Order[]
  payments               Payment[]
  communicationLogs      CommunicationLog[]
  refreshTokens          RefreshToken[]
  adminAuditLogs         AdminAuditLog[]
  tagBatchesGenerated    TagBatch[]          @relation("tagBatchesGenerated")
  contactMessagesReplied ContactMessage[]    @relation("contactMessageRepliedBy")
  contactRepliesSent     ContactReply[]      @relation("contactReplySentBy")
  tagGiftCodesCreated    TagGiftCode[]       @relation("tagGiftCodeCreatedBy")
  tagGiftRedemptions     TagGiftRedemption[] @relation("tagGiftRedemptions")
  blogPostsAuthored      BlogPost[]          @relation("blogPostsAuthored")

  @@index([deletedAt])
  @@map("users")
}

model SavedAddress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  address1  String
  address2  String?
  city      String
  state     String
  postcode  String
  country   String  @default("AU")
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
  @@map("saved_addresses")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model VerificationToken {
  id         String    @id @default(cuid())
  identifier String
  token      String    @unique
  type       String // EMAIL_VERIFY | PHONE_VERIFY | PASSWORD_RESET
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier, type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ──────────────────────────────────────────────
// BLOG
// ──────────────────────────────────────────────

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String
  content         String
  coverImageUrl   String?
  category        String?
  tags            String[]  @default([])
  isPublished     Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  authorId        String?
  author          User?     @relation("blogPostsAuthored", fields: [authorId], references: [id], onDelete: SetNull)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@index([isFeatured])
  @@index([deletedAt])
  @@map("blog_posts")
}

// ──────────────────────────────────────────────
// CONTACT MESSAGES
// ──────────────────────────────────────────────

model ContactMessage {
  id          String               @id @default(cuid())
  name        String
  email       String
  message     String
  status      ContactMessageStatus @default(NEW)
  repliedAt   DateTime?
  repliedById String?
  repliedBy   User?                @relation("contactMessageRepliedBy", fields: [repliedById], references: [id])

  replies ContactReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@map("contact_messages")
}

model ContactReply {
  id        String         @id @default(cuid())
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  subject   String
  body      String
  sentById  String?
  sentBy    User?          @relation("contactReplySentBy", fields: [sentById], references: [id])
  sentAt    DateTime       @default(now())

  @@index([messageId])
  @@map("contact_replies")
}

// ──────────────────────────────────────────────
// TAGS (QR Tokens)
// ──────────────────────────────────────────────

model Tag {
  id     String    @id @default(cuid())
  token  String    @unique // 12-char base62 via crypto.randomBytes(9)
  type   TagType   @default(GENERIC)
  status TagStatus @default(INACTIVE)

  // Owner link (nullable: tags exist before being claimed)
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  // Tag metadata set by owner
  label       String?
  description String?
  photoUrl    String?

  // Lost mode
  isLostMode      Boolean   @default(true)
  lostModeAt      DateTime?
  lostModeMessage String?

  // Contact preferences per tag
  allowVoiceCall    Boolean @default(true)
  allowSms          Boolean @default(true)
  allowWhatsApp     Boolean @default(false)
  allowSendLocation Boolean @default(true)

  // Activation
  activatedAt   DateTime?
  deactivatedAt DateTime?

  // Expiry / renewal (the QR is the paid product and expires)
  expiresAt             DateTime?
  autoRenew             Boolean   @default(false)
  renewalPriceInCents   Int?
  renewalReminderSentAt DateTime?

  // Batch tracking (admin-generated tags)
  batchId String?
  batch   TagBatch? @relation(fields: [batchId], references: [id])

  // QR asset storage
  qrPngUrl     String?
  qrSvgUrl     String?
  qrFrameStyle QrFrameStyle @default(SCAN2CALL_TOP)
  qrLayout     QrLayout     @default(STANDARD)

  // Order item link (tag created from order)
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])

  // Soft delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  scans               Scan[]
  communicationLogs   CommunicationLog[]
  tagGiftRedemptions  TagGiftRedemption[]
  reservedForGiftCode TagGiftCode?        @relation("ReservedTagGiftCode")
  payments            Payment[]

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@index([batchId])
  @@index([orderItemId])
  @@index([deletedAt])
  @@index([expiresAt])
  @@map("tags")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model TagBatch {
  id                   String       @id @default(cuid())
  name                 String
  quantity             Int
  tagType              TagType
  generatedBy          String
  generatedByUser      User         @relation("tagBatchesGenerated", fields: [generatedBy], references: [id])
  notes                String?
  qrFrameStyle         QrFrameStyle @default(SCAN2CALL_TOP)
  qrLayout             QrLayout     @default(STANDARD)
  // QR period (years) bundled with retail packaging; applied as expiry when a blank tag is claimed
  bundledDurationYears Int          @default(1)
  createdAt            DateTime     @default(now())

  tags Tag[]

  @@index([generatedBy])
  @@map("tag_batches")
}

// ──────────────────────────────────────────────
// SCANS (Audit Log)
// ──────────────────────────────────────────────

model Scan {
  id      String  @id @default(cuid())
  tagId   String
  tag     Tag     @relation(fields: [tagId], references: [id])
  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id])

  // Finder context (privacy-respecting)
  ipAddress String? // SHA-256 hashed, never raw
  userAgent String?
  latitude  Float?
  longitude Float?
  city      String?
  country   String?

  // Scan outcome
  contactInitiated Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([tagId])
  @@index([ownerId])
  @@index([createdAt])
  @@map("scans")
}

// ──────────────────────────────────────────────
// COMMUNICATION (Anonymous Relay)
// ──────────────────────────────────────────────

model CommunicationLog {
  id      String  @id @default(cuid())
  tagId   String
  tag     Tag     @relation(fields: [tagId], references: [id])
  ownerId String
  owner   User    @relation(fields: [ownerId], references: [id])
  scanId  String?

  type   CommunicationType
  status CommunicationStatus @default(INITIATED)

  // Twilio references
  twilioSessionSid String?
  twilioCallSid    String?
  twilioMessageSid String?
  proxyNumber      String?

  // Metadata (NO real finder phone stored)
  durationSeconds Int?
  messageCount    Int?

  // Timestamps
  initiatedAt DateTime  @default(now())
  connectedAt DateTime?
  endedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tagId])
  @@index([ownerId])
  @@index([twilioSessionSid])
  @@index([createdAt])
  @@map("communication_logs")
}

// ──────────────────────────────────────────────
// PRODUCTS (Store)
// ──────────────────────────────────────────────

model Product {
  id               String  @id @default(cuid())
  name             String
  slug             String  @unique
  description      String
  shortDescription String?

  // Pricing (AUD cents)
  // priceInCents is the PER-YEAR (QR yearly) price. Total scales with the duration chosen at checkout.
  priceInCents       Int
  compareAtPrice     Int?
  // Find My devices (Pet Collar, Keychain): flat device price that INCLUDES year 1.
  // Each additional year adds priceInCents. null/0 for sticker/band products.
  devicePriceInCents Int?
  hasFindMy          Boolean @default(false)

  // Inventory
  sku           String  @unique
  stockQuantity Int     @default(0)
  isInStock     Boolean @default(true)

  // Product details
  tagType          TagType?
  includesTagCount Int      @default(0)

  // Media
  images ProductImage[]

  // Display
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)
  sortOrder  Int     @default(0)

  // SEO
  metaTitle       String?
  metaDescription String?

  // Stripe
  stripePriceId   String?
  stripeProductId String?

  // Soft delete
  deletedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderItems OrderItem[]

  @@index([isActive, isFeatured])
  @@index([deletedAt])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// ──────────────────────────────────────────────
// ORDERS
// ──────────────────────────────────────────────

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // SC-YYYYMMDD-XXXX
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING)

  // Pricing (AUD cents)
  subtotalInCents Int
  shippingInCents Int    @default(0)
  taxInCents      Int    @default(0)
  discountInCents Int    @default(0)
  totalInCents    Int
  currency        String @default("AUD")

  // Shipping address (snapshot at order time)
  shippingFirstName String
  shippingLastName  String
  shippingAddress1  String
  shippingAddress2  String?
  shippingCity      String
  shippingState     String
  shippingPostcode  String
  shippingCountry   String  @default("AU")

  // Tracking
  trackingNumber  String?
  trackingCarrier String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Stripe
  stripePaymentIntentId String? @unique

  // Notes
  customerNotes String?
  internalNotes String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // Snapshot at order time
  productName       String
  productSku        String
  quantity          Int
  unitPriceInCents  Int
  totalPriceInCents Int

  // QR duration / renewal (chosen at checkout)
  durationYears       Int     @default(1)
  autoRenew           Boolean @default(false)
  renewalPriceInCents Int     @default(0)

  // Tag customization (set by user at checkout)
  tagLabel       String?
  tagDescription String?

  // Tags generated for this item (one per unit)
  tags Tag[]

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

// ──────────────────────────────────────────────
// TAG GIFTING
// ──────────────────────────────────────────────

model TagGiftCode {
  id             String         @id @default(cuid())
  code           String         @unique
  status         GiftCodeStatus @default(ACTIVE)
  tagType        TagType        @default(GENERIC)
  expiresAt      DateTime?
  maxRedemptions Int            @default(1)
  redeemedCount  Int            @default(0)
  reservedTagId  String?        @unique

  createdById String
  createdBy   User   @relation("tagGiftCodeCreatedBy", fields: [createdById], references: [id])
  reservedTag Tag?   @relation("ReservedTagGiftCode", fields: [reservedTagId], references: [id])

  redemptions TagGiftRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([expiresAt])
  @@map("tag_gift_codes")
}

model TagGiftRedemption {
  id         String   @id @default(cuid())
  giftCodeId String
  userId     String
  tagId      String
  redeemedAt DateTime @default(now())
  note       String?

  giftCode TagGiftCode @relation(fields: [giftCodeId], references: [id], onDelete: Cascade)
  user     User        @relation("tagGiftRedemptions", fields: [userId], references: [id])
  tag      Tag         @relation(fields: [tagId], references: [id])

  @@unique([giftCodeId, userId])
  @@index([giftCodeId])
  @@index([userId])
  @@index([tagId])
  @@map("tag_gift_redemptions")
}

// ──────────────────────────────────────────────
// PAYMENTS / INVOICES
// ──────────────────────────────────────────────

model Payment {
  id      String        @id @default(cuid())
  userId  String
  user    User          @relation(fields: [userId], references: [id])
  orderId String?       @unique
  order   Order?        @relation(fields: [orderId], references: [id])
  // Tag link for renewal charges (no order)
  tagId   String?
  tag     Tag?          @relation(fields: [tagId], references: [id])
  type    PaymentType   @default(PURCHASE)
  status  PaymentStatus @default(PENDING)

  amountInCents Int
  currency      String @default("AUD")

  // Stripe
  stripePaymentIntentId String? @unique
  stripeInvoiceId       String?
  stripeChargeId        String?
  paymentMethod         String?
  cardLast4             String?
  cardBrand             String?

  // Refund
  refundedAmountInCents Int       @default(0)
  refundedAt            DateTime?

  // Receipt
  receiptUrl String?

  // Timestamps
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([tagId])
  @@map("payments")
}

model ProcessedWebhookEvent {
  id          String   @id
  provider    String
  eventType   String
  processedAt DateTime @default(now())

  @@index([provider, eventType])
  @@map("processed_webhook_events")
}

// ──────────────────────────────────────────────
// ADMIN AUDIT LOG
// ──────────────────────────────────────────────

model AdminAuditLog {
  id         String          @id @default(cuid())
  adminId    String
  admin      User            @relation(fields: [adminId], references: [id])
  action     AdminActionType
  targetType String
  targetId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}
