# Scan2Call Production Environment Variables
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to version control!

# ──────────────────────────────────────────────
# Database (used by docker-compose)
# ──────────────────────────────────────────────
POSTGRES_DB=scan2call
POSTGRES_USER=scan2call_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ──────────────────────────────────────────────
# ──────────────────────────────────────────────
# Server Ports
# ──────────────────────────────────────────────
API_PORT=3001
APP_HOST=scan2call.net
WWW_APP_HOST=www.scan2call.net
API_HOST=api.scan2call.net

# ──────────────────────────────────────────────
# Auth (JWT RS256) - Generate new keys for production!
# Use: node -e "const c=require('crypto');const{publicKey,privateKey}=c.generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log('PRIVATE:',Buffer.from(privateKey).toString('base64'));console.log('PUBLIC:',Buffer.from(publicKey).toString('base64'))"
# ──────────────────────────────────────────────
JWT_ACCESS_PRIVATE_KEY=GENERATE_NEW_KEY_BASE64_ENCODED
JWT_ACCESS_PUBLIC_KEY=GENERATE_NEW_KEY_BASE64_ENCODED
JWT_REFRESH_SECRET=GENERATE_64_CHAR_RANDOM_STRING

# ──────────────────────────────────────────────
# Twilio
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PROXY_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_VERIFY_SERVICE_SID=

# ──────────────────────────────────────────────
# Resend (Email)
# ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@scan2call.net

# ──────────────────────────────────────────────
# Google OAuth
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.scan2call.net/api/v1/auth/google/callback

# ──────────────────────────────────────────────
# Facebook OAuth
# ──────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://api.scan2call.net/api/v1/auth/facebook/callback

# ──────────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=

# ──────────────────────────────────────────────
# S3-Compatible Storage (Cloudflare R2)
# ──────────────────────────────────────────────
S3_BUCKET=scan2call-media
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_URL=

# ──────────────────────────────────────────────
# Cloudflare Turnstile
# ──────────────────────────────────────────────
# Public site key is baked into the frontend image at build time.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Secret key is used by the API at runtime to verify tokens.
TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────────
# App URLs
# ──────────────────────────────────────────────
APP_URL=https://scan2call.net
API_URL=https://api.scan2call.net
CORS_ORIGINS=https://scan2call.net,https://www.scan2call.net
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.scan2call.net

# ──────────────────────────────────────────────
# Revalidation
# ──────────────────────────────────────────────
REVALIDATION_SECRET=GENERATE_32_CHAR_RANDOM_STRING
