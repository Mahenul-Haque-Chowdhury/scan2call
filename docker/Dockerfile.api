FROM node:24-bookworm-slim AS builder

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

RUN corepack enable

WORKDIR /app

COPY . .

RUN pnpm install --frozen-lockfile

RUN pnpm exec prisma generate

RUN rm -rf packages/shared/dist && pnpm -C packages/shared exec tsc -p tsconfig.build.json --incremental false && pnpm -C apps/api exec nest build

RUN pnpm deploy --filter @scan2call/api --prod /prod/api --legacy

FROM node:24-bookworm-slim AS runner

ENV NODE_ENV=production

WORKDIR /app

RUN apt-get update \
	&& apt-get install -y --no-install-recommends \
		wget \
		fontconfig \
		fonts-dejavu-core \
	&& rm -rf /var/lib/apt/lists/*

COPY apps/api/assets/fonts/space-grotesk /usr/share/fonts/truetype/space-grotesk
RUN fc-cache -f

COPY --from=builder /prod/api ./
COPY --from=builder /app/packages/shared/dist ./node_modules/.pnpm/@scan2call+shared@file+packages+shared/node_modules/@scan2call/shared/dist
COPY --from=builder /app/prisma ./prisma
COPY --from=builder /app/prisma.config.ts ./prisma.config.ts

EXPOSE 3001

CMD ["node", "dist/main.js"]
