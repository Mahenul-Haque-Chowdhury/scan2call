{
  "name": "scan2call",
  "private": true,
  "version": "0.0.1",
  "description": "Privacy-first digital identity platform with anonymous QR-based communication relay",
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm db:generate && turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^5.0.2",
    "bcrypt": "^5.1.1",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3"
  }
}
